@model ScreeningResponseViewModel

@functions {
    /// <summary>
    /// A lightweight parser to convert basic AI Markdown elements (bold, lists, headers)
    /// into beautifully styled, safe HTML blocks.
    /// </summary>
    public Microsoft.AspNetCore.Html.HtmlString FormatReportSummary(string input)
    {
        if (string.IsNullOrEmpty(input))
            return new Microsoft.AspNetCore.Html.HtmlString("<p class='text-slate-400 italic'>No evaluation notes available.</p>");

        // 1. Normalize line endings
        string html = System.Net.WebUtility.HtmlEncode(input).Replace("\r\n", "\n").Replace("\n", "<br />");

        // 2. Format headers (e.g. ### Header or #### Header)
        html = System.Text.RegularExpressions.Regex.Replace(html, @"###\s*(.*?)(?=<br\s*/?>|$)", "<h4 class='text-base font-bold text-slate-800 mt-4 mb-2 flex items-center'><i class='fa-solid fa-circle-info text-indigo-500 mr-2 text-xs'></i>$1</h4>");
        html = System.Text.RegularExpressions.Regex.Replace(html, @"####\s*(.*?)(?=<br\s*/?>|$)", "<h5 class='text-sm font-bold text-slate-700 mt-3 mb-1.5 uppercase tracking-wider'>$1</h5>");

        // 3. Format Bold elements (**text**)
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.*?)\*\*", "<strong class='text-slate-900 font-semibold'>$1</strong>");

        // 4. Format bullet points (e.g., - Skill or * Skill) into styled, pill-like dynamic list tags
        html = System.Text.RegularExpressions.Regex.Replace(html, @"(?<=^|<br\s*/?>)\s*[-\*]\s*(.*?)(?=$|<br\s*/?>)",
            "<span class='inline-flex items-center px-3 py-1 rounded-full bg-slate-100 text-slate-800 text-xs font-semibold border border-slate-200 mr-2 mb-2 shadow-xs transition-colors hover:bg-slate-200'><span class='w-1.5 h-1.5 rounded-full bg-indigo-500 mr-2'></span>$1</span>");

        // Clean up redundant double break lines
        html = html.Replace("<br /><br />", "<br />");

        return new Microsoft.AspNetCore.Html.HtmlString(html);
    }
}

@{
    var recommendation = Model.Result.Recommendation?.ToLower() ?? "";
    string cardBorderClass = "border-amber-200";
    string badgeClass = "bg-amber-50 text-amber-800 border-amber-200";
    string bgHeaderGradient = "from-slate-800 to-slate-900";
    string iconClass = "fa-circle-question text-amber-500";
    string nextStepMessage = "Schedule a standard telephone screening call to explore credentials.";

    if (recommendation.Contains("hire"))
    {
        cardBorderClass = "border-emerald-200";
        badgeClass = "bg-emerald-50 text-emerald-800 border-emerald-200";
        bgHeaderGradient = "from-indigo-900 to-slate-900";
        iconClass = "fa-circle-check text-emerald-500";
        nextStepMessage = "Highly recommended! Initiate technical screening or schedule an immediate interview.";
    }
    else if (recommendation.Contains("interview"))
    {
        cardBorderClass = "border-indigo-200";
        badgeClass = "bg-indigo-50 text-indigo-800 border-indigo-200";
        bgHeaderGradient = "from-slate-850 to-slate-900";
        iconClass = "fa-comments text-indigo-500";
        nextStepMessage = "Schedule a technical chat to deep dive into candidate qualifications and skills gaps.";
    }
    else if (recommendation.Contains("reject") || recommendation.Contains("no"))
    {
        cardBorderClass = "border-rose-200";
        badgeClass = "bg-rose-50 text-rose-800 border-rose-200";
        bgHeaderGradient = "from-rose-950 to-slate-950";
        iconClass = "fa-circle-xmark text-rose-500";
        nextStepMessage = "Archive CV in talent database or draft standard candidate polite rejection notice.";
    }

    var score = Model.Result.Score;
    string scoreColor = "text-rose-500 border-rose-200 bg-rose-50";
    string barColor = "bg-rose-500";
    if (score >= 80)
    {
        scoreColor = "text-emerald-600 border-emerald-200 bg-emerald-50";
        barColor = "bg-emerald-500";
    }
    else if (score >= 50)
    {
        scoreColor = "text-amber-500 border-amber-200 bg-amber-50";
        barColor = "bg-amber-500";
    }
}

<div class="max-w-4xl mx-auto space-y-6">
    <!-- Back Navigation Top Bar -->
    <div class="flex items-center justify-between">
        <a asp-controller="Screening" asp-action="Index" class="inline-flex items-center text-sm font-semibold text-indigo-600 hover:text-indigo-800 transition-colors">
            <i class="fa-solid fa-arrow-left mr-2"></i> Back to Candidate Input
        </a>
        <span class="text-xs text-slate-400 font-mono">Job Match Pipeline v1.4</span>
    </div>

    <!-- Main Screening Report Dashboard Card -->
    <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-slate-100">
        <!-- Dashboard Header Hero -->
        <div class="bg-gradient-to-r @bgHeaderGradient text-white p-6 md:p-8 relative">
            <div class="absolute top-4 right-4 opacity-10">
                <i class="fa-solid fa-briefcase text-8xl"></i>
            </div>

            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 relative z-10">
                <div>
                    <span class="text-xs font-bold text-indigo-300 tracking-wider uppercase bg-indigo-950/40 px-3 py-1 rounded-full border border-indigo-500/30">
                        AI Screening Agent Assessment
                    </span>
                    <h2 class="text-3xl font-black mt-3 text-white tracking-tight">@Model.CandidateName</h2>
                    <p class="text-slate-300 text-sm mt-1.5 flex items-center">
                        <i class="fa-solid fa-briefcase text-xs mr-2 text-indigo-300"></i> Target Role:
                        <span class="text-white font-semibold ml-1">@Model.JobTitle</span>
                    </p>
                </div>

                <!-- Match Compatibility Metric Gauge -->
                <div class="flex items-center bg-white/5 backdrop-blur-md p-4 rounded-xl border border-white/10">
                    <div class="text-center mr-4">
                        <span class="block text-[10px] uppercase font-bold tracking-widest text-slate-300">Compatibility</span>
                        <span class="text-3xl font-black text-white leading-none">@score%</span>
                    </div>
                    <div class="w-12 h-12 rounded-full border-2 @scoreColor flex flex-col items-center justify-center font-black text-base shadow-inner">
                        @score
                    </div>
                </div>
            </div>
        </div>

        <!-- Dashboard Content Body -->
        <div class="p-6 md:p-8 space-y-8">

            <!-- Quick Action & Assessment Band -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <!-- Status Recommendation -->
                <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl flex items-center space-x-4 md:col-span-2">
                    <div class="p-3 rounded-lg bg-white shadow-xs">
                        <i class="fa-solid @iconClass text-2xl"></i>
                    </div>
                    <div>
                        <span class="text-[10px] uppercase font-bold tracking-wider text-slate-400 block">Assessment Status</span>
                        <span class="px-2.5 py-0.5 border rounded-full text-xs font-bold @badgeClass uppercase tracking-wider">
                            @Model.Result.Recommendation
                        </span>
                    </div>
                </div>

                <!-- Match Progress Meter -->
                <div class="bg-slate-50 border border-slate-200 p-4 rounded-xl flex flex-col justify-center">
                    <div class="flex justify-between items-center text-xs font-semibold text-slate-500 mb-1.5">
                        <span>Overall Grade Score</span>
                        <span>@score / 100</span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-2.5 overflow-hidden">
                        <div class="@barColor h-full rounded-full transition-all duration-500" style="width: @score%"></div>
                    </div>
                </div>
            </div>

            <!-- Interactive Skills Comparison Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- Column 1: Core Matched Credentials -->
                <div class="bg-emerald-50/20 border border-emerald-100 rounded-xl p-5 hover:bg-emerald-50/30 transition-all">
                    <h4 class="text-sm font-bold text-emerald-800 uppercase tracking-wider mb-4 flex items-center">
                        <i class="fa-solid fa-square-check text-emerald-600 mr-2.5 text-base"></i> Matched Qualifications
                    </h4>

                    @if (Model.Result.MatchingSkills != null && Model.Result.MatchingSkills.Count > 0 && Model.Result.MatchingSkills[0] != "Review text details below")
                    {
                        <div class="flex flex-wrap gap-2">
                            @foreach (var skill in Model.Result.MatchingSkills)
                            {
                                <span class="px-3 py-1 bg-white border border-emerald-200 text-emerald-900 rounded-lg text-xs font-bold shadow-xs flex items-center">
                                    <span class="w-2 h-2 rounded-full bg-emerald-500 mr-2"></span> @skill
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-6 text-slate-400 italic text-sm">
                            <i class="fa-solid fa-rectangle-list block text-slate-300 text-2xl mb-2"></i>
                            Skills extracted in the Executive Summary report below.
                        </div>
                    }
                </div>

                <!-- Column 2: Identified Gaps & Missing Skills -->
                <div class="bg-rose-50/20 border border-rose-100 rounded-xl p-5 hover:bg-rose-50/30 transition-all">
                    <h4 class="text-sm font-bold text-rose-800 uppercase tracking-wider mb-4 flex items-center">
                        <i class="fa-solid fa-circle-exclamation text-rose-600 mr-2.5 text-base"></i> Gaps & Missing Gaps
                    </h4>

                    @if (Model.Result.MissingSkills != null && Model.Result.MissingSkills.Count > 0 && Model.Result.MissingSkills[0] != "Review text details below")
                    {
                        <div class="flex flex-wrap gap-2">
                            @foreach (var skill in Model.Result.MissingSkills)
                            {
                                <span class="px-3 py-1 bg-white border border-rose-200 text-rose-900 rounded-lg text-xs font-bold shadow-xs flex items-center">
                                    <span class="w-2 h-2 rounded-full bg-rose-500 mr-2"></span> @skill
                                </span>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-6 text-emerald-600 text-sm font-semibold flex flex-col items-center justify-center">
                            <i class="fa-solid fa-circle-check text-emerald-500 text-2xl mb-2"></i>
                            Perfect criteria coverage or detailed in the Summary report below.
                        </div>
                    }
                </div>
            </div>

            <!-- Executive Summary (Formatted markdown support) -->
            <div class="space-y-3">
                <h3 class="text-sm font-bold uppercase tracking-wider text-slate-500 flex items-center border-b border-slate-100 pb-2">
                    <i class="fa-solid fa-chart-line mr-2.5 text-indigo-500 text-base"></i> Comprehensive Analysis Report
                </h3>

                <div class="bg-indigo-50/30 border border-indigo-100/70 p-6 rounded-2xl text-slate-700 text-sm leading-relaxed shadow-xs">
                    <div class="prose max-w-none text-slate-700 font-sans">
                        @FormatReportSummary(Model.Result.Summary)
                    </div>
                </div>
            </div>

            <!-- Human-In-The-Loop HR Next Step -->
            <div class="bg-slate-50 rounded-xl p-4 border border-slate-200 flex items-start space-x-3 text-slate-600">
                <i class="fa-solid fa-lightbulb text-indigo-500 text-lg mt-0.5"></i>
                <div class="text-xs">
                    <strong class="text-slate-800 block mb-0.5">Recommended Next Action:</strong>
                    @nextStepMessage
                </div>
            </div>

            <!-- Footer Toolbar Action -->
            <div class="pt-6 border-t border-slate-100 flex justify-end gap-3">
                <button onclick="window.print();" class="px-5 py-2.5 border border-slate-300 rounded-lg text-xs font-bold text-slate-600 hover:bg-slate-50 transition-colors flex items-center space-x-2">
                    <i class="fa-solid fa-print"></i>
                    <span>Print Report</span>
                </button>
                <a asp-controller="Screening" asp-action="Index" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-bold shadow-sm transition-colors flex items-center space-x-2">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <span>Screen Another CV</span>
                </a>
            </div>

        </div>
    </div>
</div>