@model ScreeningRequestViewModel
<div class="bg-white rounded-2xl shadow-xl p-6 md:p-8 max-w-4xl mx-auto border border-slate-100">
    <div class="text-center mb-8">
        <h2 class="text-2xl md:text-3xl font-bold text-slate-900">AI Resume Evaluator</h2>
        <p class="text-slate-500 mt-2">Evaluate candidate qualification scores, extract matching skills, and analyze gaps using .NET MVC and your automated n8n AI Agent Tool.</p>
    </div>

    @if (!ViewData.ModelState.IsValid && ViewData.ModelState.Values.Any(v => v.Errors.Any()))
    {
        <div class="bg-rose-50 border-l-4 border-rose-500 text-rose-700 p-4 mb-6 rounded shadow-sm flex items-start space-x-2">
            <i class="fa-solid fa-triangle-exclamation mt-1"></i>
            <div>
                <p class="font-bold">Execution Error</p>
                <div asp-validation-summary="All" class="text-sm list-none"></div>
            </div>
        </div>
    }

    <form asp-controller="Screening" asp-action="Process" method="post" enctype="multipart/form-data" class="space-y-6">
        @Html.AntiForgeryToken()

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Candidate Name -->
            <div>
                <label asp-for="CandidateName" class="block text-sm font-semibold text-slate-700 mb-2">
                    <i class="fa-solid fa-user text-slate-400 mr-2"></i>Candidate Full Name
                </label>
                <input asp-for="CandidateName" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" placeholder="e.g. Jane Doe" />
                <span asp-validation-for="CandidateName" class="text-xs text-rose-500 mt-1 block"></span>
            </div>

            <!-- Job Title -->
            <div>
                <label asp-for="JobTitle" class="block text-sm font-semibold text-slate-700 mb-2">
                    <i class="fa-solid fa-briefcase text-slate-400 mr-2"></i>Target Job Title
                </label>
                <input asp-for="JobTitle" class="w-full px-4 py-2.5 rounded-lg border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all" placeholder="e.g. Senior Dotnet Developer" />
                <span asp-validation-for="JobTitle" class="text-xs text-rose-500 mt-1 block"></span>
            </div>
        </div>

        <!-- Job Description -->
        <div>
            <label asp-for="JobDescription" class="block text-sm font-semibold text-slate-700 mb-2">
                <i class="fa-solid fa-file-invoice text-slate-400 mr-2"></i>Job Description / Requirements
            </label>
            <textarea asp-for="JobDescription" rows="5" class="w-full px-4 py-3 rounded-lg border border-slate-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 outline-none transition-all font-sans text-sm" placeholder="Paste structural job requirements, tech stacks, and credentials here..."></textarea>
            <span asp-validation-for="JobDescription" class="text-xs text-rose-500 mt-1 block"></span>
        </div>

        <!-- CV File Upload -->
        <div>
            <label asp-for="CvFile" class="block text-sm font-semibold text-slate-700 mb-2">
                <i class="fa-solid fa-file-arrow-up text-slate-400 mr-2"></i>Candidate CV Document (.txt, .pdf)
            </label>
            <div class="mt-1 flex justify-center px-6 pt-5 pb-6 border-2 border-slate-300 border-dashed rounded-lg hover:border-indigo-500 transition-colors">
                <div class="space-y-1 text-center">
                    <i class="fa-solid fa-cloud-arrow-up text-slate-400 text-3xl mb-3 block"></i>
                    <div class="flex text-sm text-slate-600">
                        <label for="CvFile" class="relative cursor-pointer bg-white rounded-md font-medium text-indigo-600 hover:text-indigo-500 focus-within:outline-none">
                            <span>Upload a file</span>
                            <input id="CvFile" name="CvFile" type="file" accept=".txt,.pdf" class="sr-only" required />
                        </label>
                        <p class="pl-1">or drag and drop</p>
                    </div>
                    <p class="text-xs text-slate-500">Plain text (.txt) or PDF (.pdf) up to 10MB</p>
                    <span id="file-chosen" class="text-sm font-semibold text-indigo-600 mt-2 block italic">No file selected</span>
                </div>
            </div>
            <span asp-validation-for="CvFile" class="text-xs text-rose-500 mt-1 block"></span>
        </div>

        <div class="flex justify-end pt-2">
            <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold px-8 py-3.5 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center space-x-2">
                <i class="fa-solid fa-magnifying-glass-chart"></i>
                <span>Submit to AI Agent</span>
            </button>
        </div>
    </form>
</div>

<!-- Simple script to display the chosen file name in the UI -->
<script>
    document.getElementById('CvFile').addEventListener('change', function() {
        var fileName = this.files.length > 0 ? this.files[0].name : "No file selected";
        document.getElementById('file-chosen').textContent = "Selected: " + fileName;
    });
</script>