<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TalentMatch AI Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col justify-between">
    <!-- Navbar Header -->
    <header class="bg-indigo-700 text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
            <div class="flex items-center space-x-3">
                <i class="fa-solid py-1 px-2.5 bg-indigo-500 rounded-lg fa-robot text-2xl"></i>
                <h1 class="text-xl font-bold tracking-tight">TalentMatch <span class="text-indigo-200 font-light">AI</span></h1>
            </div>
            <span class="text-xs bg-indigo-600 px-3 py-1 rounded-full border border-indigo-400">n8n Live Workflow</span>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow max-w-5xl w-full mx-auto px-4 py-8">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-slate-950 text-slate-400 py-6 text-center text-sm border-t border-slate-800">
        <p>© @DateTime.Now.Year TalentMatch AI. Structured .NET MVC + n8n Orchestrated Pipeline.</p>
    </footer>
</body>
</html>